{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**/node_modules/**",
      "tests/**",
      "reference/**",
      "public/**",
      "serve.py",
      "sync-to-github.js",
      "HANDOFF.md",
      "README.md",
      "skills-lock.json",
      "*.patch"
    ],
    "rewrites": [
      { "source": "/api/analytics", "function": "analytics" }
    ],
    "headers": [
      {
        "source": "**/*.@(html)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ]
  }
}
